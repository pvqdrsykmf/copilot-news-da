# Alpaca credentials — usa SEMPRE quelle paper finché non sei pronto al live
# Registrati su https://alpaca.markets/ e crea una key in "Paper Trading"
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# false = paper trading (default, sicuro)
# true  = live trading (richiede anche LIVE_CONFIRM=I_KNOW_WHAT_I_AM_DOING)
ALPACA_LIVE=false
LIVE_CONFIRM=

# Risk management (parametri di sicurezza globali)
MAX_POSITION_PCT=0.10           # max 10% del portafoglio per singola posizione
MAX_GROSS_EXPOSURE=1.0          # 1.0 = no leva; 1.5 = leva 1.5x
DAILY_LOSS_LIMIT_PCT=0.03       # circuit breaker: stop trading se -3% in un giorno
MAX_DRAWDOWN_PCT=0.15           # stop trading se DD totale > 15%

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Database
DB_PATH=./data/trading.db
